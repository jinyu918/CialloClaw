{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CialloClaw",
  "version": "0.1.0",
  "identifier": "com.cialloclaw.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "shell-ball",
        "title": "CialloClaw Shell Ball",
        "width": 420,
        "height": 640,
        "decorations": false,
        "transparent": true,
        "url": "shell-ball.html"
      },
      {
        "label": "dashboard",
        "title": "CialloClaw Dashboard",
        "width": 1280,
        "height": 860,
        "url": "dashboard.html"
      },
      {
        "label": "control-panel",
        "title": "CialloClaw Control Panel",
        "width": 1080,
        "height": 760,
        "url": "control-panel.html"
      },
      {
        "label": "mirror",
        "title": "CialloClaw Mirror",
        "width": 1180,
        "height": 820,
        "url": "mirror.html"
      }
    ]
  }
}
