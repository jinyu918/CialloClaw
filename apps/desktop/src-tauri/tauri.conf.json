{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CialloClaw",
  "version": "0.1.0",
  "identifier": "com.cialloclaw.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "shell-ball",
        "title": "CialloClaw Shell Ball",
        "width": 144,
        "height": 156,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "url": "shell-ball.html"
      },
      {
        "label": "shell-ball-bubble",
        "title": "CialloClaw Shell Ball Bubble",
        "width": 270,
        "height": 105,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "url": "shell-ball-bubble.html"
      },
      {
        "label": "shell-ball-input",
        "title": "CialloClaw Shell Ball Input",
        "width": 315,
        "height": 90,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "url": "shell-ball-input.html"
      },
      {
        "label": "dashboard",
        "title": "CialloClaw Dashboard",
        "width": 1280,
        "height": 860,
        "decorations": false,
        "visible": false,
        "url": "dashboard.html"
      },
      {
        "label": "control-panel",
        "title": "CialloClaw Control Panel",
        "width": 1080,
        "height": 760,
        "decorations": false,
        "visible": false,
        "url": "control-panel.html"
      }
    ]
  }
}
